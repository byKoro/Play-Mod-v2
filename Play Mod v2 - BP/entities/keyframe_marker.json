{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "playmod:keyframe_marker",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false
    },
    "components": {
      "minecraft:type_family": {
        "family": ["playmod_keyframe_marker", "inanimate"]
      },

      // Sem física: não cai, não flutua na água, não é empurrado por
      // pistão nem por outras entidades.
      "minecraft:physics": {
        "has_gravity": false,
        "has_collision": false
      },
      "minecraft:pushable": {
        "is_pushable": false,
        "is_pushable_by_piston": false
      },
      "minecraft:knockback_resistance": {
        "value": 1
      },

      // "Imortal": nenhuma causa de dano (fogo, sufocamento, afogamento,
      // explosão, ataque, void, etc.) tira vida dela. O único jeito de
      // remover é via /kill (que ignora o sistema de dano por completo)
      // — isso é detectado e revertido pelo script
      // (keyframeMarkerService.js, ver world.afterEvents.entityDie).
      "minecraft:health": {
        "value": 1,
        "max": 1
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "all",
            "deals_damage": false
          }
        ]
      },
      "minecraft:is_immune_to_fire": {},

      // Nenhum componente de despawn: por padrão, uma entidade custom
      // sem "minecraft:despawn" não some sozinha nunca. Só é removida
      // quando o próprio script chama entity.remove() (ao desligar o
      // toggle, iniciar a animação, ou reconstruir os marcadores).
      "minecraft:collision_box": {
        "width": 0.5,
        "height": 0.5
      }
    }
  }
}
